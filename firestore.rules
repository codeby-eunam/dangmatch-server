rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 식당 컬렉션 ──────────────────────────────────────────────────────────
    match /restaurants/{placeId} {
      // 읽기: 누구나 (랭킹, 카드 표시 등)
      allow read: if true;

      // 생성 / 업데이트: 누구나 허용
      // → 카카오 공개 데이터이므로 비로그인 유저도 저장 가능
      // → stats 포함 모든 필드 업데이트 허용
      allow create, update: if true;
    }

    // ── 유저 컬렉션 ──────────────────────────────────────────────────────────
    match /users/{uid} {
      // 본인 문서만 읽기·쓰기
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // ── 토너먼트 히스토리 ─────────────────────────────────────────────────────
    match /tournament_history/{docId} {
      // 읽기: 누구나 (랭킹 집계 등)
      allow read: if true;
      // 쓰기: 누구나 (비로그인 유저도 결과 기록, uid: null 허용)
      allow create: if true;
    }

    // ── 피드백 / 신고 ─────────────────────────────────────────────────────────
    match /feedback/{docId} {
      // 읽기: 닫힘 (Firebase 콘솔에서 직접 확인)
      allow read: if false;
      // 제출: 누구나 (비로그인 사용자도 피드백 가능)
      allow create: if true;
    }

    // ── 유저 리스트 (서브컬렉션) ──────────────────────────────────────────────
    // 본인만 읽기·쓰기
    match /users/{uid}/lists/{listId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── 공유 리스트 ───────────────────────────────────────────────────────────
    // 읽기: 누구나 (비로그인 공유 링크 열람)
    // 쓰기: 소유자만 (create 포함 — resource가 없을 때는 request.resource 사용)
    match /shared_lists/{token} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerUid;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.ownerUid;
    }

    // ── 학교 피드 ─────────────────────────────────────────────────────────────
    // 맛집 랭킹: 읽기 누구나, 쓰기는 로그인 유저
    match /school_feeds/{schoolDomain}/restaurants/{restaurantId} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }

    // 공유 리스트: 읽기 누구나, 작성자만 수정/삭제
    match /school_feeds/{schoolDomain}/lists/{listId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.createdBy;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;
    }

    // ── 학교 변경 건의 ────────────────────────────────────────────────────────
    // 읽기: 닫힘 (Firebase 콘솔에서 관리자가 직접 확인)
    // 쓰기: 로그인 유저만
    match /reports/{docId} {
      allow read: if false;
      allow create: if request.auth != null;
    }
  }
}
